ODOO_URL=https://your-tenant.odoo.com
ODOO_DB=your-db-name
ODOO_UID=your-user-id
ODOO_API_KEY=replace-with-real-api-key

# Whitelist: which companies the user can pick from (res.company IDs)
COMPANY_IDS=1,11

# Whitelist: employees to show, matched by last whitespace-delimited word
# of their name (Vietnamese given name). Case-insensitive.
EMPLOYEE_NAME_KEYWORDS=Phước,Thành,Công,Biên,Chinh

# Whitelist: expense category IDs (product.product). Find IDs in Odoo via:
#   Settings → Technical → Database Structure → Products
#   or in JSON-RPC: search_read("product.product", [("default_code","ilike","...")], ["id","default_code","name"])
CATEGORY_IDS=26807,26758,157600,26808,27054,148975,172089,119083,170275

# Whitelist: currency codes (res.currency.name). If exactly 1 matches, the
# currency dropdown is hidden and the value is submitted via a hidden field.
CURRENCY_CODES=VND